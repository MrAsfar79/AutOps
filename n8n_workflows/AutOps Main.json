    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst msg = (input.chatInput || '').trim().toLowerCase();\n\nconst isApprove = msg.startsWith('!approve');\nconst isDeny = msg.startsWith('!deny');\nconst isLogs = msg.startsWith('!logs');\n\nif (!isApprove && !isDeny && !isLogs) {\n  return [{ json: { ...input, route: 'ai' } }];\n}\n\nconst parts = msg.split(' ');\nconst containerName = parts[1] || null;\n\nif (!containerName) {\n  return [{\n    json: {\n      ...input,\n      route: 'reply',\n      reply: '⚠️ Please specify a container name.\\nExample: `!approve website`'\n    }\n  }];\n}\n\nif (isApprove) {\n  return [{ json: { ...input, route: 'approve', container: containerName } }];\n}\n\nif (isDeny) {\n  return [{ json: { ...input, route: 'deny', container: containerName } }];\n}\n\nif (isLogs) {\n  return [{ json: { ...input, route: 'logs', container: containerName } }];\n}"
      },
