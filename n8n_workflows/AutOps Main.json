    {
      "parameters": {
        "jsCode": "const container = $('Command Router').first().json.container;\nconst command = $('Validate Pending').first().json.command || '';\nconst stdout = $input.first().json.stdout || '';\nconst stderr = $input.first().json.stderr || '';\n\n// Clear pending action\nconst staticData = $getWorkflowStaticData('global');\nif (staticData.pendingActions) {\n  delete staticData.pendingActions[container];\n}\n\n// --- NEW BRANCHED LOGIC ---\nlet success = false;\n\nif (container === 'nginx') {\n  // systemctl commands are silent on success. If there's no error in stderr, it worked.\n  success = !stderr; \n} else {\n  // Standard Docker check: requires the container name in stdout\n  success = !stderr && stdout.includes(container);\n}\n// ---------------------------\n\n// Determine the action verb for the Discord reply\nlet action;\nif (/\\bstop\\b/.test(command)) action = 'stopped';\nelse if (/\\bstart\\b/.test(command)) action = 'started';\nelse if (/\\brestart\\b/.test(command)) action = 'restarted';\nelse if (/\\breload\\b/.test(command)) action = 'reloaded'; // Added for Nginx\nelse action = 'executed';\n\nreturn [{\n  json: {\n    channel_id: $('Edit Fields').first().json.channel_id,\n    reply: success\n      ? `✅ \\`${container}\\` ${action} successfully.`\n      : `❌ Failed to run \\`${command}\\` on \\`${container}\\`.\\n\\`\\`\\`${stderr || stdout || 'No output returned.'}\\`\\`\\``\n  }\n}];"
      },
