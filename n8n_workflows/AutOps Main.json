    {
      "parameters": {
        "jsCode": "const routerData = $('Command Router').first().json;\nconst route = routerData.route;\nconst container = routerData.container;\n\nif (route === 'ai') {\n  return [{ json: routerData }];\n}\n\nif (route === 'deny') {\n  return [{\n    json: {\n      ...routerData,\n      route: 'reply',\n      reply: `✅ Understood. \\`${container}\\` will be left as-is. No action taken.`\n    }\n  }];\n}\n\nconst rows = $input.all();\nconst match = rows.find(r => {\n  const storedName = (r.json.container || '').replace(/^=+/, '').trim();\n  return storedName === container;\n});\n\nif (!match && route !== 'logs') {\n  return [{\n    json: {\n      ...routerData,\n      route: 'reply',\n      reply: `⚠️ No pending action found for \\`${container}\\`. Either it was already handled or no alert was triggered for it.`\n    }\n  }];\n}\n\n// For logs, always use logs command regardless of table\nif (route === 'logs') {\n  return [{\n    json: {\n      ...routerData,\n      command: `docker logs ${container} --tail 20`,\n      route: 'logs'\n    }\n  }];\n}\n\nconst cleanCommand = (match.json.command || '').replace(/^=+/, '').trim();\n\nreturn [{\n  json: {\n    ...routerData,\n    command: cleanCommand,\n    route: route\n  }\n}];"
      },
