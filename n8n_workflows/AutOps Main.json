    {
      "parameters": {
        "jsCode": "const container = $('Command Router').first().json.container;\nconst channelId = $('Edit Fields').first().json.channel_id;\n\nconst item = $input.first().json;\nconst stdout = item.stdout || '';\nconst stderr = item.stderr || '';\n\n// Docker logs output goes to stderr by default\nconst logs = (stdout + stderr).trim() || 'No log output returned.';\n\nreturn [{\n  json: {\n    channel_id: channelId,\n    reply: `📋 Last 20 lines from \\`${container}\\`:\\n\\`\\`\\`\\n${logs.slice(0, 1800)}\\n\\`\\`\\``\n  }\n}];"
